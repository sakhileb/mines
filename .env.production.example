APP_NAME="OptiMine Fleet Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=optimine
DB_USERNAME=root
DB_PASSWORD=

# Session Configuration - CRITICAL FOR 419 FIX
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
# SMTP server: mines.infodot.co.za | Port: 465 | SSL/TLS (implicit)
MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=mines.infodot.co.za
MAIL_PORT=465
MAIL_USERNAME=info@mines.infodot.co.za
MAIL_PASSWORD=change_me
MAIL_FROM_ADDRESS="info@mines.infodot.co.za"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Manufacturer API Integrations
# Refer to API_INTEGRATION_GUIDELINES.md for complete setup instructions

# Volvo CareTrack
VOLVO_API_ENDPOINT=https://api.volvoce.com
VOLVO_API_KEY=
VOLVO_API_SECRET=

# Caterpillar VisionLink
CAT_API_ENDPOINT=https://api.cat.com/visionlink
CAT_API_KEY=
CAT_DEALER_CODE=

# Komatsu KOMTRAX
KOMATSU_API_ENDPOINT=https://api.komtrax.com
KOMATSU_API_KEY=
KOMATSU_CUSTOMER_ID=

# Bell Fleetmatic
BELL_API_ENDPOINT=https://api.fleetmatic.bell.com
BELL_API_TOKEN=

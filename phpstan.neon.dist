parameters:
  level: max
  paths:
    - app
    - routes
    - database
  excludePaths:
    - tests
  inferPrivatePropertyTypeFromConstructor: true
  checkExplicitMixed: false
includes:
  - vendor/phpstan/phpstan/conf/bleedingEdge.neon
  - phpstan-baseline.neon
# Note: keep a single `parameters` section above. Adjust level and paths there if needed.
# Customize autoloading or bootstrap if needed
# bootstrapFiles:
#   - %rootDir%/../../../vendor/autoload.php

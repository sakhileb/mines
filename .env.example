APP_NAME=Mines
APP_ENV=local
APP_KEY=
# Default to non-debug in examples to encourage production-safe defaults
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Session cookie settings - set these to true/strict in production
# SESSION_SECURE_COOKIE: only send cookies over HTTPS
# SESSION_HTTP_ONLY: disallow JavaScript access to cookies
# SESSION_SAME_SITE: controls cross-site cookie behavior (lax/strict/none)
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Recommended production queue driver: redis or sqs
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Monitoring & logging
# Set SENTRY_DSN to enable Sentry error reporting (optional)
SENTRY_DSN=

# Sentry environment and release (set during deploy)
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

# Papertrail UDP host/port (optional)
PAPERTRAIL_URL=
PAPERTRAIL_PORT=

# Default log channel (stack,daily,papertrail)
LOG_CHANNEL=stack

VITE_APP_NAME="${APP_NAME}"

title = "Mines repo gitleaks config"

[[rules]]
[[rules]]
id = "aws-access-key-id"
description = "AWS Access Key ID"
regex = '''AKIA[0-9A-Z]{16}'''
tags = ["aws","key"]

[[rules]]
id = "aws-secret-access-key"
description = "AWS Secret Access Key"
regex = '''(?i)aws(.{0,20})?(secret|secret_access|secretkey)(.{0,20})?[=:\s]\s*[A-Za-z0-9/+=]{40}'''
tags = ["aws","secret"]

[[rules]]
id = "generic-api-key"
description = "Generic API key"
regex = '''(?i)(api|apikey|secret|token)["'`\s:=\/]{0,5}[A-Za-z0-9\-_.]{20,}'''
tags = ["key"]

# Optional allowlists (files or commits to ignore) can be added here if needed

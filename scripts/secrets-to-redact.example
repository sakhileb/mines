# Example replacements for git-filter-repo --replace-text
# Format: literal-to-replace==>[replacement]
# Lines beginning with '#' are comments and ignored.

# Example:
# AKIAEXAMPLEKEY1234567890==>[REDACTED_AWS_KEY]
# SENTRY_EXAMPLE_TOKEN==>[REDACTED_SENTRY_TOKEN]

# Replace with actual secrets (one per line) before running git-filter-repo.
